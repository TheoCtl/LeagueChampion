"""
Pokemon League Champion - 2D World System
Tile-based map with procedural tile graphics, player character,
camera system, NPCs, and interaction zones.
"""
import pygame
import math
import random

# ─── Constants ──────────────────────────────────────────────────────

TILE_SIZE = 48
MOVE_DURATION = 0.15   # seconds per tile movement

# ─── Tile Definitions ──────────────────────────────────────────────

TILE_DEFS = {
    ' ': {'walkable': False},
    '.': {'walkable': True},         # stone floor
    'c': {'walkable': True},         # red carpet
    'w': {'walkable': True},         # wood floor
    'd': {'walkable': True},         # dark stone floor
    'g': {'walkable': True},         # grass
    'r': {'walkable': True},         # road / path
    'f': {'walkable': True},         # flowers on grass
    '#': {'walkable': False},        # wall
    'X': {'walkable': False},        # wall with torch
    'V': {'walkable': False},        # wall with banner
    'W': {'walkable': False},        # wall with window
    'H': {'walkable': False},        # wall bottom face (visible)
    'P': {'walkable': False},        # pillar
    'T': {'walkable': False},        # throne platform
    'K': {'walkable': False},        # throne seat
    'B': {'walkable': False},        # bookshelf
    'U': {'walkable': False},        # table
    'Y': {'walkable': False},        # trophy
    'O': {'walkable': False},        # pokeball display
    'M': {'walkable': False},        # statue
    'N': {'walkable': False},        # sign post
    'A': {'walkable': True, 'interaction': 'arena'},
    'S': {'walkable': True, 'interaction': 'shop'},
    'E': {'walkable': True, 'interaction': 'exit'},
    'L': {'walkable': False, 'interaction': 'league'},
    'R': {'walkable': False},        # railing / fence
    'D': {'walkable': True},         # dark carpet
    '~': {'walkable': False},        # water
    'G': {'walkable': True},         # gate floor (entrance transition)
}

# ─── Color Palette ──────────────────────────────────────────────────

# Tiles
C_STONE        = (148, 152, 162)
C_STONE_LINE   = (120, 124, 134)
C_STONE_LIGHT  = (165, 168, 178)
C_CARPET       = (170, 38, 48)
C_CARPET_DARK  = (138, 28, 35)
C_CARPET_GOLD  = (218, 178, 52)
C_WOOD         = (152, 112, 72)
C_WOOD_DARK    = (122, 88, 55)
C_WOOD_LINE    = (112, 80, 50)
C_WALL         = (72, 80, 92)
C_WALL_DARK    = (55, 60, 72)
C_WALL_MORTAR  = (60, 68, 78)
C_WALL_LIGHT   = (88, 95, 108)
C_GRASS        = (80, 162, 58)
C_GRASS_DARK   = (62, 132, 44)
C_GRASS_LIGHT  = (95, 180, 72)
C_ROAD         = (188, 172, 142)
C_ROAD_LINE    = (168, 152, 122)
C_ROAD_DARK    = (158, 142, 112)
C_PILLAR       = (168, 172, 182)
C_PILLAR_DARK  = (128, 132, 142)
C_PILLAR_LIGHT = (195, 198, 208)
C_WATER        = (68, 135, 210)
C_WATER_LIGHT  = (95, 165, 235)

# Player character
C_SKIN         = (255, 212, 172)
C_HAIR         = (48, 40, 58)
C_COAT         = (188, 38, 45)
C_COAT_DARK    = (148, 28, 35)
C_COAT_GOLD    = (238, 198, 58)
C_PANTS        = (45, 45, 65)
C_SHOES        = (65, 40, 30)


# ─── Tile Surface Generation ──────────────────────────────────────

class TileSet:
    """Generates and caches all tile surfaces as 48x48 pixel art."""

    def __init__(self):
        # Seed for reproducible decorative randomness
        rng = random.Random(42)
        self._tiles = {}
        self._generate_all(rng)

    def get(self, char):
        return self._tiles.get(char, self._tiles.get(' '))

    # ── generators ──────────────────────────────────────────────────

    def _generate_all(self, rng):
        s = TILE_SIZE

        # void
        surf = pygame.Surface((s, s))
        surf.fill((0, 0, 0))
        self._tiles[' '] = surf

        self._tiles['.'] = self._stone_floor(rng)
        self._tiles['d'] = self._dark_floor()
        self._tiles['c'] = self._carpet()
        self._tiles['D'] = self._dark_carpet()
        self._tiles['w'] = self._wood_floor(rng)
        self._tiles['#'] = self._wall()
        self._tiles['H'] = self._wall_face()
        self._tiles['X'] = self._wall_torch()
        self._tiles['V'] = self._wall_banner()
        self._tiles['W'] = self._wall_window()
        self._tiles['P'] = self._pillar()
        self._tiles['T'] = self._throne_platform()
        self._tiles['K'] = self._throne_seat()
        self._tiles['B'] = self._bookshelf(rng)
        self._tiles['U'] = self._table()
        self._tiles['Y'] = self._trophy()
        self._tiles['O'] = self._pokeball_stand()
        self._tiles['M'] = self._statue()
        self._tiles['N'] = self._sign_post()
        self._tiles['g'] = self._grass(rng)
        self._tiles['r'] = self._road()
        self._tiles['f'] = self._flowers(rng)
        self._tiles['A'] = self._arena_mat()
        self._tiles['S'] = self._shop_mat()
        self._tiles['E'] = self._exit_mat()
        self._tiles['L'] = self._league_board()
        self._tiles['R'] = self._railing()
        self._tiles['~'] = self._water(rng)
        self._tiles['G'] = self._gate_floor()

    # ── individual tile builders ────────────────────────────────────

    def _stone_floor(self, rng):
        s = TILE_SIZE
        surf = pygame.Surface((s, s))
        surf.fill(C_STONE)
        # Subtle block grid
        pygame.draw.line(surf, C_STONE_LINE, (0, 0), (s, 0), 1)
        pygame.draw.line(surf, C_STONE_LINE, (0, 0), (0, s), 1)
        pygame.draw.line(surf, C_STONE_LINE, (s // 2, 0), (s // 2, s), 1)
        pygame.draw.line(surf, C_STONE_LINE, (0, s // 2), (s, s // 2), 1)
        # Noise specks
        for _ in range(4):
            nx = rng.randint(2, s - 3)
            ny = rng.randint(2, s - 3)
            c = rng.choice([C_STONE_LINE, C_STONE_LIGHT])
            surf.set_at((nx, ny), c)
        return surf

    def _dark_floor(self):
        s = TILE_SIZE
        surf = pygame.Surface((s, s))
        dark = (98, 102, 112)
        surf.fill(dark)
        pygame.draw.line(surf, (82, 86, 96), (0, 0), (s, 0), 1)
        pygame.draw.line(surf, (82, 86, 96), (0, 0), (0, s), 1)
        return surf

    def _carpet(self):
        s = TILE_SIZE
        surf = pygame.Surface((s, s))
        surf.fill(C_CARPET)
        pygame.draw.rect(surf, C_CARPET_DARK, (0, 0, s, s), 2)
        pygame.draw.rect(surf, C_CARPET_GOLD, (3, 3, s - 6, s - 6), 1)
        # Center diamond
        cx, cy = s // 2, s // 2
        pts = [(cx, cy - 7), (cx + 7, cy), (cx, cy + 7), (cx - 7, cy)]
        pygame.draw.polygon(surf, C_CARPET_DARK, pts, 1)
        return surf

    def _dark_carpet(self):
        s = TILE_SIZE
        surf = pygame.Surface((s, s))
        surf.fill((130, 30, 38))
        pygame.draw.rect(surf, (110, 22, 30), (0, 0, s, s), 2)
        return surf

    def _wood_floor(self, rng):
        s = TILE_SIZE
        surf = pygame.Surface((s, s))
        surf.fill(C_WOOD)
        for y in range(0, s, 12):
            pygame.draw.line(surf, C_WOOD_LINE, (0, y), (s, y), 1)
        for i in range(0, s, 12):
            off = ((i // 12) % 2) * (s // 2)
            pygame.draw.line(surf, C_WOOD_LINE, (off + s // 4, i),
                             (off + s // 4, min(i + 12, s)), 1)
        for y in range(3, s, 12):
            pygame.draw.line(surf, C_WOOD_DARK, (4, y), (s - 4, y), 1)
        return surf

    def _wall(self):
        s = TILE_SIZE
        surf = pygame.Surface((s, s))
        surf.fill(C_WALL)
        bh = 12
        for row in range(s // bh + 1):
            y = row * bh
            off = (row % 2) * (s // 2)
            pygame.draw.line(surf, C_WALL_MORTAR, (0, y), (s, y), 1)
            for x in range(off, s + s, s // 2):
                if 0 <= x < s:
                    pygame.draw.line(surf, C_WALL_MORTAR, (x, y),
                                     (x, min(y + bh, s)), 1)
        pygame.draw.line(surf, C_WALL_LIGHT, (0, 1), (s, 1), 1)
        pygame.draw.line(surf, C_WALL_DARK, (0, s - 1), (s, s - 1), 2)
        return surf

    def _wall_face(self):
        """Bottom-facing wall edge (visible face of wall in top-down)."""
        s = TILE_SIZE
        surf = pygame.Surface((s, s))
        surf.fill(C_WALL_DARK)
        # Stone blocks
        bh = 16
        for row in range(s // bh + 1):
            y = row * bh
            off = (row % 2) * (s // 3)
            pygame.draw.line(surf, C_WALL_MORTAR, (0, y), (s, y), 1)
            for x in range(off, s + s, s // 3):
                if 0 <= x < s:
                    pygame.draw.line(surf, C_WALL_MORTAR, (x, y),
                                     (x, min(y + bh, s)), 1)
        # Shadow at top
        pygame.draw.line(surf, (35, 38, 48), (0, 0), (s, 0), 3)
        return surf

    def _wall_torch(self):
        s = TILE_SIZE
        surf = self._wall().copy()
        # Bracket
        pygame.draw.rect(surf, (125, 82, 42), (s // 2 - 3, s // 2 - 6, 6, 14))
        # Flame
        pygame.draw.ellipse(surf, (255, 185, 42), (s // 2 - 5, s // 2 - 14, 10, 12))
        pygame.draw.ellipse(surf, (255, 225, 85), (s // 2 - 3, s // 2 - 12, 6, 8))
        # Glow
        glow = pygame.Surface((s, s), pygame.SRCALPHA)
        pygame.draw.circle(glow, (255, 180, 40, 35), (s // 2, s // 2 - 6), 18)
        surf.blit(glow, (0, 0))
        return surf

    def _wall_banner(self):
        s = TILE_SIZE
        surf = self._wall().copy()
        # Pole
        pygame.draw.rect(surf, (182, 162, 122), (s // 2 - 12, 4, 24, 3))
        # Banner fabric
        pts = [(s // 2 - 10, 7), (s // 2 + 10, 7),
               (s // 2 + 8, s - 8), (s // 2, s - 4), (s // 2 - 8, s - 8)]
        pygame.draw.polygon(surf, C_COAT, pts)
        pygame.draw.polygon(surf, C_CARPET_GOLD, pts, 2)
        # Pokeball emblem
        pygame.draw.circle(surf, C_CARPET_GOLD, (s // 2, s // 2 + 2), 5, 1)
        pygame.draw.line(surf, C_CARPET_GOLD,
                         (s // 2 - 5, s // 2 + 2), (s // 2 + 5, s // 2 + 2), 1)
        return surf

    def _wall_window(self):
        s = TILE_SIZE
        surf = self._wall().copy()
        wx, wy, ww, wh = s // 2 - 8, 6, 16, 24
        pygame.draw.rect(surf, (62, 52, 42), (wx - 1, wy - 1, ww + 2, wh + 2))
        pygame.draw.rect(surf, (132, 198, 248), (wx, wy, ww, wh))
        pygame.draw.line(surf, (62, 52, 42), (s // 2, wy), (s // 2, wy + wh), 2)
        pygame.draw.line(surf, (62, 52, 42), (wx, wy + wh // 2),
                         (wx + ww, wy + wh // 2), 2)
        pygame.draw.line(surf, (202, 228, 255), (wx + 2, wy + 2),
                         (wx + 5, wy + 5), 1)
        return surf

    def _pillar(self):
        s = TILE_SIZE
        surf = self._stone_floor(random.Random(99)).copy()
        px, pw = s // 2 - 8, 16
        pygame.draw.rect(surf, C_PILLAR, (px, 0, pw, s))
        pygame.draw.rect(surf, C_PILLAR_DARK, (px, 0, 5, s))
        pygame.draw.rect(surf, C_PILLAR_LIGHT, (px + pw - 5, 0, 5, s))
        # Capital
        pygame.draw.rect(surf, C_PILLAR_LIGHT, (px - 3, 0, pw + 6, 6))
        pygame.draw.rect(surf, C_PILLAR_DARK, (px - 3, 0, pw + 6, 6), 1)
        # Base
        pygame.draw.rect(surf, C_PILLAR_LIGHT, (px - 2, s - 6, pw + 4, 6))
        pygame.draw.rect(surf, C_PILLAR_DARK, (px - 2, s - 6, pw + 4, 6), 1)
        return surf

    def _throne_platform(self):
        s = TILE_SIZE
        surf = pygame.Surface((s, s))
        surf.fill((128, 118, 102))
        pygame.draw.rect(surf, (148, 138, 120), (2, 2, s - 4, s - 4))
        pygame.draw.rect(surf, (102, 92, 80), (0, 0, s, s), 2)
        pygame.draw.rect(surf, C_CARPET_GOLD, (2, 2, s - 4, s - 4), 1)
        return surf

    def _throne_seat(self):
        s = TILE_SIZE
        surf = self._throne_platform().copy()
        # Backrest
        pygame.draw.rect(surf, (182, 142, 52), (s // 2 - 10, 0, 20, 22))
        pygame.draw.rect(surf, C_CARPET_GOLD, (s // 2 - 10, 0, 20, 22), 2)
        # Crown ornament
        pts = [(s // 2 - 6, 4), (s // 2 - 3, 0), (s // 2, 3),
               (s // 2 + 3, 0), (s // 2 + 6, 4)]
        pygame.draw.polygon(surf, C_CARPET_GOLD, pts)
        # Seat cushion
        pygame.draw.rect(surf, C_CARPET, (s // 2 - 8, 22, 16, 12))
        pygame.draw.rect(surf, C_CARPET_DARK, (s // 2 - 8, 22, 16, 12), 1)
        # Armrests
        pygame.draw.rect(surf, (182, 142, 52), (s // 2 - 14, 18, 6, 18))
        pygame.draw.rect(surf, (182, 142, 52), (s // 2 + 8, 18, 6, 18))
        pygame.draw.rect(surf, C_CARPET_GOLD, (s // 2 - 14, 18, 6, 18), 1)
        pygame.draw.rect(surf, C_CARPET_GOLD, (s // 2 + 8, 18, 6, 18), 1)
        return surf

    def _bookshelf(self, rng):
        s = TILE_SIZE
        surf = pygame.Surface((s, s))
        surf.fill((82, 60, 40))
        # Shelves
        for y in [0, s // 3, 2 * s // 3]:
            pygame.draw.rect(surf, C_WOOD, (0, y, s, 4))
        # Books
        book_colors = [(168, 48, 48), (48, 88, 168), (48, 148, 68),
                       (188, 148, 48), (148, 48, 148), (48, 148, 168),
                       (198, 78, 48), (78, 168, 58)]
        for shelf_y in [4, s // 3 + 4, 2 * s // 3 + 4]:
            x = 4
            for _ in range(6):
                bw = rng.randint(4, 7)
                bh = s // 3 - 7
                col = rng.choice(book_colors)
                pygame.draw.rect(surf, col, (x, shelf_y, bw, bh))
                x += bw + 1
                if x > s - 6:
                    break
        # Frame
        pygame.draw.rect(surf, C_WOOD_DARK, (0, 0, s, s), 2)
        return surf

    def _table(self):
        s = TILE_SIZE
        surf = self._stone_floor(random.Random(77)).copy()
        pygame.draw.rect(surf, C_WOOD, (4, 8, s - 8, s - 16))
        pygame.draw.rect(surf, C_WOOD_DARK, (4, 8, s - 8, s - 16), 2)
        pygame.draw.rect(surf, (172, 132, 88), (6, 10, s - 12, 3))
        for lx in [7, s - 11]:
            pygame.draw.rect(surf, C_WOOD_DARK, (lx, s - 10, 4, 8))
        return surf

    def _trophy(self):
        s = TILE_SIZE
        surf = self._stone_floor(random.Random(55)).copy()
        # Pedestal
        pygame.draw.rect(surf, (158, 150, 140), (s // 2 - 10, s - 14, 20, 14))
        pygame.draw.rect(surf, (128, 120, 110), (s // 2 - 10, s - 14, 20, 14), 1)
        # Cup
        pygame.draw.rect(surf, C_CARPET_GOLD, (s // 2 - 6, 14, 12, 18))
        pygame.draw.rect(surf, (238, 198, 58), (s // 2 - 8, 10, 16, 8))
        # Handles
        pygame.draw.arc(surf, C_CARPET_GOLD,
                        (s // 2 - 14, 14, 10, 12), 1.57, 4.71, 2)
        pygame.draw.arc(surf, C_CARPET_GOLD,
                        (s // 2 + 4, 14, 10, 12), -1.57, 1.57, 2)
        # Star
        pygame.draw.circle(surf, (255, 248, 182), (s // 2, 16), 3)
        return surf

    def _pokeball_stand(self):
        s = TILE_SIZE
        surf = self._stone_floor(random.Random(33)).copy()
        # Stand
        pygame.draw.rect(surf, (82, 82, 92), (s // 2 - 8, s // 2 + 2, 16, s // 2 - 2))
        pygame.draw.rect(surf, (98, 98, 108), (s // 2 - 10, s // 2, 20, 4))
        # Pokeball - top (red)
        pygame.draw.circle(surf, (232, 42, 42), (s // 2, s // 2 - 6), 10)
        # Bottom (white) - draw over bottom half
        pygame.draw.rect(surf, (242, 242, 248), (s // 2 - 10, s // 2 - 6, 20, 10))
        pygame.draw.circle(surf, (242, 242, 248), (s // 2, s // 2 + 4), 10)
        # Re-draw top arc
        pygame.draw.circle(surf, (232, 42, 42), (s // 2, s // 2 - 6), 10)
        pygame.draw.rect(surf, (242, 242, 248), (s // 2 - 10, s // 2 - 6, 20, 11))
        # Cleaner approach: just draw two halves
        pygame.draw.circle(surf, (42, 42, 48), (s // 2, s // 2 - 6), 10, 1)
        # Center line
        pygame.draw.line(surf, (42, 42, 48),
                         (s // 2 - 10, s // 2 - 6), (s // 2 + 10, s // 2 - 6), 2)
        # Center button
        pygame.draw.circle(surf, (242, 242, 248), (s // 2, s // 2 - 6), 4)
        pygame.draw.circle(surf, (42, 42, 48), (s // 2, s // 2 - 6), 4, 1)
        pygame.draw.circle(surf, (242, 242, 248), (s // 2, s // 2 - 6), 2)
        return surf

    def _statue(self):
        s = TILE_SIZE
        surf = self._stone_floor(random.Random(44)).copy()
        # Base
        pygame.draw.rect(surf, (142, 142, 152), (s // 2 - 10, s - 12, 20, 12))
        pygame.draw.rect(surf, (112, 112, 122), (s // 2 - 10, s - 12, 20, 12), 1)
        # Body (abstract Pokemon silhouette)
        pygame.draw.ellipse(surf, (162, 162, 172), (s // 2 - 8, 10, 16, 26))
        pygame.draw.ellipse(surf, (132, 132, 142), (s // 2 - 8, 10, 16, 26), 1)
        # Head
        pygame.draw.circle(surf, (172, 172, 182), (s // 2, 12), 8)
        pygame.draw.circle(surf, (132, 132, 142), (s // 2, 12), 8, 1)
        return surf

    def _sign_post(self):
        s = TILE_SIZE
        surf = self._stone_floor(random.Random(66)).copy()
        # Post
        pygame.draw.rect(surf, C_WOOD_DARK, (s // 2 - 2, s // 2, 4, s // 2))
        # Sign board
        pygame.draw.rect(surf, C_WOOD, (s // 2 - 12, 8, 24, 18))
        pygame.draw.rect(surf, C_WOOD_DARK, (s // 2 - 12, 8, 24, 18), 2)
        # Text lines
        pygame.draw.line(surf, (200, 185, 155), (s // 2 - 8, 14),
                         (s // 2 + 8, 14), 1)
        pygame.draw.line(surf, (200, 185, 155), (s // 2 - 6, 19),
                         (s // 2 + 6, 19), 1)
        return surf

    def _grass(self, rng):
        s = TILE_SIZE
        surf = pygame.Surface((s, s))
        surf.fill(C_GRASS)
        # Grass blades
        for _ in range(10):
            gx = rng.randint(2, s - 4)
            gy = rng.randint(2, s - 4)
            c = rng.choice([C_GRASS_DARK, C_GRASS_LIGHT])
            pygame.draw.line(surf, c, (gx, gy + 4), (gx, gy), 1)
            pygame.draw.line(surf, c, (gx + 2, gy + 3), (gx + 3, gy), 1)
        return surf

    def _road(self):
        s = TILE_SIZE
        surf = pygame.Surface((s, s))
        surf.fill(C_ROAD)
        pygame.draw.rect(surf, C_ROAD_LINE, (0, 0, s, s), 1)
        pygame.draw.line(surf, C_ROAD_LINE, (s // 2, 0), (s // 2, s), 1)
        pygame.draw.line(surf, C_ROAD_LINE, (0, s // 2), (s, s // 2), 1)
        # Subtle shadow at edges
        pygame.draw.line(surf, C_ROAD_DARK, (0, s - 1), (s, s - 1), 1)
        pygame.draw.line(surf, C_ROAD_DARK, (s - 1, 0), (s - 1, s), 1)
        return surf

    def _flowers(self, rng):
        s = TILE_SIZE
        surf = self._grass(rng).copy()
        colors = [(255, 102, 102), (255, 255, 102), (255, 152, 255),
                  (102, 152, 255), (255, 182, 102)]
        for _ in range(5):
            fx = rng.randint(4, s - 6)
            fy = rng.randint(4, s - 6)
            col = rng.choice(colors)
            pygame.draw.circle(surf, col, (fx, fy), 3)
            pygame.draw.circle(surf, (255, 255, 202), (fx, fy), 1)
        return surf

    def _arena_mat(self):
        s = TILE_SIZE
        surf = pygame.Surface((s, s))
        surf.fill((168, 44, 44))
        pygame.draw.rect(surf, C_CARPET_GOLD, (0, 0, s, s), 3)
        # Battle pokeball emblem
        pygame.draw.circle(surf, (218, 62, 62), (s // 2, s // 2), 12, 2)
        pygame.draw.line(surf, (218, 62, 62),
                         (s // 2 - 12, s // 2), (s // 2 + 12, s // 2), 2)
        pygame.draw.circle(surf, (255, 255, 255), (s // 2, s // 2), 4)
        pygame.draw.circle(surf, (218, 62, 62), (s // 2, s // 2), 4, 1)
        return surf

    def _shop_mat(self):
        s = TILE_SIZE
        surf = pygame.Surface((s, s))
        surf.fill((44, 88, 168))
        pygame.draw.rect(surf, C_CARPET_GOLD, (0, 0, s, s), 3)
        # Potion bottle emblem
        pygame.draw.rect(surf, (122, 202, 122), (s // 2 - 4, s // 2 - 6, 8, 14))
        pygame.draw.rect(surf, (182, 232, 182), (s // 2 - 6, s // 2 - 10, 12, 6))
        pygame.draw.rect(surf, (82, 172, 82), (s // 2 - 4, s // 2 - 6, 8, 14), 1)
        return surf

    def _exit_mat(self):
        s = TILE_SIZE
        surf = self._road().copy()
        # Arrow pointing down
        pts = [(s // 2, s - 8), (s // 2 - 8, s - 18), (s // 2 + 8, s - 18)]
        pygame.draw.polygon(surf, C_CARPET_GOLD, pts)
        pygame.draw.polygon(surf, (188, 158, 42), pts, 1)
        return surf

    def _league_board(self):
        s = TILE_SIZE
        surf = self._wall().copy()
        bx, by, bw, bh = 4, 4, s - 8, s - 8
        pygame.draw.rect(surf, (62, 48, 32), (bx, by, bw, bh))
        pygame.draw.rect(surf, (102, 82, 52), (bx, by, bw, bh), 2)
        # Text lines
        for i in range(4):
            ly = by + 6 + i * 8
            lw = (bw - 8) - i * 3
            pygame.draw.line(surf, (182, 172, 142), (bx + 4, ly),
                             (bx + 4 + lw, ly), 2)
        return surf

    def _railing(self):
        s = TILE_SIZE
        surf = self._stone_floor(random.Random(88)).copy()
        pygame.draw.rect(surf, C_WOOD, (0, s // 2 - 4, s, 8))
        pygame.draw.rect(surf, C_WOOD_DARK, (0, s // 2 - 4, s, 8), 1)
        # Posts
        for x in [4, s - 8]:
            pygame.draw.rect(surf, C_WOOD_DARK, (x, s // 2 - 8, 4, 16))
        return surf

    def _water(self, rng):
        s = TILE_SIZE
        surf = pygame.Surface((s, s))
        surf.fill(C_WATER)
        # Wave lines
        for y in range(0, s, 8):
            for x in range(0, s, 12):
                ox = rng.randint(-2, 2)
                pygame.draw.arc(surf, C_WATER_LIGHT, (x + ox, y, 10, 6),
                                0, 3.14, 1)
        return surf

    def _gate_floor(self):
        s = TILE_SIZE
        surf = pygame.Surface((s, s))
        surf.fill(C_STONE)
        pygame.draw.line(surf, C_STONE_LINE, (0, 0), (s, 0), 1)
        pygame.draw.line(surf, C_STONE_LINE, (0, 0), (0, s), 1)
        # Subtle arrival marker
        pygame.draw.rect(surf, C_STONE_LIGHT, (4, 4, s - 8, s - 8), 1)
        return surf


# ─── Player Sprite Generation ─────────────────────────────────────

def _generate_player_sprites():
    """Generate player sprites for 4 directions × 3 frames.
    Returns dict: {(direction, frame): Surface}
    """
    sprites = {}
    for direction in ('down', 'up', 'left', 'right'):
        for frame in range(3):
            sprites[(direction, frame)] = _draw_player(direction, frame)
    return sprites


def _draw_player(direction, frame):
    s = TILE_SIZE
    surf = pygame.Surface((s, s), pygame.SRCALPHA)

    bob = -1 if frame in (1, 2) else 0
    leg_phase = {0: 0, 1: -1, 2: 1}[frame]

    cx = s // 2

    if direction == 'down':
        _draw_front(surf, cx, bob, leg_phase)
    elif direction == 'up':
        _draw_back(surf, cx, bob, leg_phase)
    elif direction == 'left':
        _draw_side(surf, cx, bob, leg_phase, flip=False)
    elif direction == 'right':
        _draw_side(surf, cx, bob, leg_phase, flip=True)

    return surf


def _draw_front(surf, cx, bob, lp):
    y = bob
    # Cape behind
    pygame.draw.rect(surf, C_COAT_DARK, (cx - 11, 16 + y, 22, 18))
    # Hair
    pygame.draw.ellipse(surf, C_HAIR, (cx - 9, 2 + y, 18, 16))
    # Face
    pygame.draw.ellipse(surf, C_SKIN, (cx - 7, 5 + y, 14, 12))
    # Hair bangs
    pygame.draw.ellipse(surf, C_HAIR, (cx - 8, 2 + y, 16, 8))
    # Eyes
    pygame.draw.rect(surf, (32, 32, 58), (cx - 5, 10 + y, 3, 3))
    pygame.draw.rect(surf, (32, 32, 58), (cx + 2, 10 + y, 3, 3))
    pygame.draw.rect(surf, (255, 255, 255), (cx - 4, 10 + y, 1, 1))
    pygame.draw.rect(surf, (255, 255, 255), (cx + 3, 10 + y, 1, 1))
    # Coat
    pygame.draw.rect(surf, C_COAT, (cx - 9, 17 + y, 18, 14))
    # Gold details
    pygame.draw.rect(surf, C_COAT_GOLD, (cx - 1, 19 + y, 2, 2))
    pygame.draw.rect(surf, C_COAT_GOLD, (cx - 1, 24 + y, 2, 2))
    pygame.draw.line(surf, C_COAT_GOLD, (cx - 9, 17 + y), (cx - 4, 20 + y), 2)
    pygame.draw.line(surf, C_COAT_GOLD, (cx + 9, 17 + y), (cx + 4, 20 + y), 2)
    # Arms
    pygame.draw.rect(surf, C_COAT, (cx - 12, 18 + y, 4, 10))
    pygame.draw.rect(surf, C_COAT, (cx + 8, 18 + y, 4, 10))
    pygame.draw.rect(surf, C_SKIN, (cx - 12, 27 + y, 4, 3))
    pygame.draw.rect(surf, C_SKIN, (cx + 8, 27 + y, 4, 3))
    # Legs
    lo = lp * 3
    pygame.draw.rect(surf, C_PANTS, (cx - 6 + lo, 31 + y, 5, 9))
    pygame.draw.rect(surf, C_PANTS, (cx + 1 - lo, 31 + y, 5, 9))
    # Shoes
    pygame.draw.rect(surf, C_SHOES, (cx - 7 + lo, 39 + y, 7, 4))
    pygame.draw.rect(surf, C_SHOES, (cx + 0 - lo, 39 + y, 7, 4))


def _draw_back(surf, cx, bob, lp):
    y = bob
    # Cape
    pts = [(cx - 12, 15 + y), (cx + 12, 15 + y),
           (cx + 14, 34 + y), (cx - 14, 34 + y)]
    pygame.draw.polygon(surf, C_COAT, pts)
    pygame.draw.polygon(surf, C_COAT_DARK, pts, 2)
    pygame.draw.line(surf, C_COAT_GOLD, (cx - 14, 34 + y), (cx + 14, 34 + y), 2)
    # Hair
    pygame.draw.ellipse(surf, C_HAIR, (cx - 9, 2 + y, 18, 16))
    # Shoulders
    pygame.draw.rect(surf, C_COAT, (cx - 9, 15 + y, 18, 8))
    pygame.draw.line(surf, C_COAT_GOLD, (cx - 9, 15 + y), (cx + 9, 15 + y), 2)
    # Legs
    lo = lp * 3
    pygame.draw.rect(surf, C_PANTS, (cx - 6 + lo, 31 + y, 5, 9))
    pygame.draw.rect(surf, C_PANTS, (cx + 1 - lo, 31 + y, 5, 9))
    # Shoes
    pygame.draw.rect(surf, C_SHOES, (cx - 7 + lo, 39 + y, 7, 4))
    pygame.draw.rect(surf, C_SHOES, (cx + 0 - lo, 39 + y, 7, 4))


def _draw_side(surf, cx, bob, lp, flip):
    y = bob
    dx = 2 if not flip else -2
    # Cape
    if flip:
        pygame.draw.rect(surf, C_COAT_DARK, (cx - 14, 15 + y, 12, 19))
        pygame.draw.line(surf, C_COAT_GOLD,
                         (cx - 14, 33 + y), (cx - 2, 33 + y), 2)
    else:
        pygame.draw.rect(surf, C_COAT_DARK, (cx + 2, 15 + y, 12, 19))
        pygame.draw.line(surf, C_COAT_GOLD,
                         (cx + 2, 33 + y), (cx + 14, 33 + y), 2)
    # Hair
    pygame.draw.ellipse(surf, C_HAIR, (cx - 8 + dx, 2 + y, 16, 16))
    # Face
    if flip:
        pygame.draw.ellipse(surf, C_SKIN, (cx - 2, 5 + y, 12, 11))
        pygame.draw.rect(surf, (32, 32, 58), (cx + 4, 9 + y, 3, 3))
        pygame.draw.rect(surf, (255, 255, 255), (cx + 5, 9 + y, 1, 1))
    else:
        pygame.draw.ellipse(surf, C_SKIN, (cx - 10, 5 + y, 12, 11))
        pygame.draw.rect(surf, (32, 32, 58), (cx - 7, 9 + y, 3, 3))
        pygame.draw.rect(surf, (255, 255, 255), (cx - 6, 9 + y, 1, 1))
    # Body
    pygame.draw.rect(surf, C_COAT, (cx - 7 + dx, 17 + y, 14, 14))
    # Gold button
    bx = cx + 2 if flip else cx - 4
    pygame.draw.rect(surf, C_COAT_GOLD, (bx, 20 + y, 2, 2))
    # Arm
    ax = cx + 5 + dx if flip else cx - 9 + dx
    pygame.draw.rect(surf, C_COAT, (ax, 18 + y, 4, 10))
    pygame.draw.rect(surf, C_SKIN, (ax, 27 + y, 4, 3))
    # Legs
    lo = lp * 3
    pygame.draw.rect(surf, C_PANTS, (cx - 4 + dx + lo, 31 + y, 5, 9))
    pygame.draw.rect(surf, C_PANTS, (cx + 1 + dx - lo, 31 + y, 5, 9))
    # Shoes
    pygame.draw.rect(surf, C_SHOES, (cx - 5 + dx + lo, 39 + y, 7, 4))
    pygame.draw.rect(surf, C_SHOES, (cx + 0 + dx - lo, 39 + y, 7, 4))


# ─── NPC Sprite Fallback ──────────────────────────────────────────

def _make_npc_fallback(name):
    """Generate a simple colored NPC sprite when no trainer sprite exists."""
    s = TILE_SIZE
    surf = pygame.Surface((s, s), pygame.SRCALPHA)
    # Deterministic color from name
    h = hash(name) % 360
    r = max(80, (h * 7 + 50) % 200 + 55)
    g = max(80, (h * 13 + 100) % 200 + 55)
    b = max(80, (h * 19 + 150) % 200 + 55)
    # Body
    pygame.draw.ellipse(surf, (r, g, b), (8, 12, 32, 28))
    # Head
    pygame.draw.circle(surf, C_SKIN, (s // 2, 12), 10)
    # Hair
    pygame.draw.ellipse(surf, (60, 50, 70), (s // 2 - 8, 2, 16, 12))
    # Eyes
    pygame.draw.rect(surf, (30, 30, 50), (s // 2 - 4, 10, 2, 2))
    pygame.draw.rect(surf, (30, 30, 50), (s // 2 + 2, 10, 2, 2))
    return surf


# ─── Camera ────────────────────────────────────────────────────────

class Camera:
    """Camera that follows the player with smooth scrolling."""

    def __init__(self, map_pw, map_ph, screen_w=1920, screen_h=1080):
        self.x = 0.0
        self.y = 0.0
        self.sw = screen_w
        self.sh = screen_h
        self.mw = map_pw
        self.mh = map_ph

    def follow(self, tx, ty, lerp=0.12):
        ix = tx - self.sw // 2
        iy = ty - self.sh // 2
        # Clamp
        ix = max(0, min(ix, self.mw - self.sw))
        iy = max(0, min(iy, self.mh - self.sh))
        self.x += (ix - self.x) * lerp
        self.y += (iy - self.y) * lerp

    def snap(self, tx, ty):
        self.x = tx - self.sw // 2
        self.y = ty - self.sh // 2
        self.x = max(0, min(self.x, self.mw - self.sw))
        self.y = max(0, min(self.y, self.mh - self.sh))

    def apply(self, x, y):
        return int(x - self.x), int(y - self.y)


# ─── Player ───────────────────────────────────────────────────────

class Player:
    """Grid-based player with smooth movement interpolation."""

    def __init__(self, gx, gy):
        self.grid_x = gx
        self.grid_y = gy
        self.pixel_x = float(gx * TILE_SIZE)
        self.pixel_y = float(gy * TILE_SIZE)
        self.direction = 'down'
        self.moving = False
        self.target_gx = gx
        self.target_gy = gy
        self.move_progress = 0.0
        self.frame = 0
        self.frame_timer = 0.0
        self.sprites = _generate_player_sprites()

    @property
    def center_x(self):
        return self.pixel_x + TILE_SIZE // 2

    @property
    def center_y(self):
        return self.pixel_y + TILE_SIZE // 2

    def try_move(self, direction, collision, map_w, map_h):
        if self.moving:
            return False
        dx, dy = {'up': (0, -1), 'down': (0, 1),
                  'left': (-1, 0), 'right': (1, 0)}[direction]
        nx, ny = self.grid_x + dx, self.grid_y + dy
        self.direction = direction
        if nx < 0 or ny < 0 or nx >= map_w or ny >= map_h:
            return False
        if not collision[ny][nx]:
            return False
        self.target_gx = nx
        self.target_gy = ny
        self.moving = True
        self.move_progress = 0.0
        return True

    def update(self, dt):
        if self.moving:
            self.move_progress += dt / MOVE_DURATION
            if self.move_progress >= 1.0:
                self.move_progress = 1.0
                self.grid_x = self.target_gx
                self.grid_y = self.target_gy
                self.moving = False
            sx = self.grid_x * TILE_SIZE
            sy = self.grid_y * TILE_SIZE
            ex = self.target_gx * TILE_SIZE
            ey = self.target_gy * TILE_SIZE
            t = self.move_progress
            t = t * t * (3 - 2 * t)   # smoothstep
            self.pixel_x = sx + (ex - sx) * t
            self.pixel_y = sy + (ey - sy) * t
            # Animate
            self.frame_timer += dt
            if self.frame_timer >= 0.12:
                self.frame_timer = 0
                self.frame = (self.frame + 1) % 3
        else:
            self.pixel_x = float(self.grid_x * TILE_SIZE)
            self.pixel_y = float(self.grid_y * TILE_SIZE)
            self.frame = 0

    def get_sprite(self):
        return self.sprites.get((self.direction, self.frame))

    def facing_tile(self):
        dx, dy = {'up': (0, -1), 'down': (0, 1),
                  'left': (-1, 0), 'right': (1, 0)}[self.direction]
        return self.grid_x + dx, self.grid_y + dy


# ─── NPC ───────────────────────────────────────────────────────────

class NPC:
    """Non-player character with trainer sprite and dialogue."""

    def __init__(self, gx, gy, name, direction='down',
                 dialogue="...", sprite_name=None, role=None):
        self.grid_x = gx
        self.grid_y = gy
        self.name = name
        self.direction = direction
        self.dialogue = dialogue
        self.sprite_name = sprite_name
        self.role = role
        self._sprite = None
        self._fallback = None

    def get_sprite(self, engine, size=None):
        sz = size or TILE_SIZE
        if self._sprite is None:
            if self.sprite_name:
                self._sprite = engine.get_trainer_sprite(self.sprite_name, sz)
            if self._sprite is None:
                self._fallback = _make_npc_fallback(self.name)
        return self._sprite or self._fallback


# ─── Game Map ──────────────────────────────────────────────────────

class GameMap:
    """Tile-based game map with collision and interaction."""

    def __init__(self, tile_data, npcs=None, name=""):
        self.name = name
        # Normalize row widths
        max_w = max(len(row) for row in tile_data) if tile_data else 0
        self.tile_data = [row.ljust(max_w) for row in tile_data]
        self.height = len(self.tile_data)
        self.width = max_w
        self.npcs = npcs or []
        self.interactions = {}

        # Build collision map (True = walkable)
        self.collision = []
        for y, row in enumerate(self.tile_data):
            cr = []
            for x in range(self.width):
                char = row[x] if x < len(row) else ' '
                td = TILE_DEFS.get(char, {'walkable': False})
                cr.append(td.get('walkable', False))
            self.collision.append(cr)

        # Mark NPC tiles as non-walkable
        for npc in self.npcs:
            if 0 <= npc.grid_y < self.height and 0 <= npc.grid_x < self.width:
                self.collision[npc.grid_y][npc.grid_x] = False

        # Build interaction map from tile data
        for y, row in enumerate(self.tile_data):
            for x, char in enumerate(row):
                td = TILE_DEFS.get(char, {})
                if 'interaction' in td:
                    self.interactions[(x, y)] = td['interaction']

        # NPC interactions: player faces NPC and presses interact
        for npc in self.npcs:
            # All 4 adjacent tiles can trigger talking to this NPC
            for ddx, ddy in [(0, 1), (0, -1), (1, 0), (-1, 0)]:
                ix, iy = npc.grid_x + ddx, npc.grid_y + ddy
                if 0 <= ix < self.width and 0 <= iy < self.height:
                    # Only add NPC interaction if the tile is walkable
                    if self.collision[iy][ix]:
                        self.interactions[(ix, iy)] = f"npc:{npc.name}"

        # Tileset & pre-render
        self.tileset = TileSet()
        self._rendered = None

    def render(self):
        if self._rendered is None:
            self._rendered = pygame.Surface(
                (self.width * TILE_SIZE, self.height * TILE_SIZE))
            for y, row in enumerate(self.tile_data):
                for x in range(self.width):
                    char = row[x] if x < len(row) else ' '
                    t = self.tileset.get(char)
                    self._rendered.blit(t, (x * TILE_SIZE, y * TILE_SIZE))
        return self._rendered

    def get_interaction(self, x, y):
        return self.interactions.get((x, y))

    def get_npc_by_name(self, name):
        for npc in self.npcs:
            if npc.name == name:
                return npc
        return None

    def pixel_width(self):
        return self.width * TILE_SIZE

    def pixel_height(self):
        return self.height * TILE_SIZE


# ─── Champion Room Map Builder ─────────────────────────────────────

def build_champion_room(league_members=None):
    """Build the Champion's Hall map procedurally."""

    W, H = 40, 30
    g = [['.' for _ in range(W)] for _ in range(H)]

    # ── Perimeter walls (indoor area rows 0-23) ──
    for x in range(W):
        g[0][x] = '#'
        g[23][x] = '#'
    for y in range(24):
        g[y][0] = '#'
        g[y][W - 1] = '#'

    # ── Entrance gap in bottom wall ──
    for x in range(17, 23):
        g[23][x] = 'G'

    # ── Red carpet runner (cols 17-22, rows 1-23) ──
    for y in range(1, 24):
        for x in range(17, 23):
            g[y][x] = 'c'

    # ── Throne area (rows 3-5, cols 5-34) ──
    for x in range(5, 35):
        g[3][x] = 'T'
        g[5][x] = 'T'
    for x in range(5, 35):
        g[4][x] = 'T'
    g[4][19] = 'K'
    g[4][20] = 'K'

    # ── Top wall decorations ──
    g[0][5]  = 'V'     # banner
    g[0][10] = 'W'     # window
    g[0][15] = 'V'     # banner
    g[0][24] = 'V'     # banner
    g[0][29] = 'W'     # window
    g[0][34] = 'V'     # banner

    # ── League board on top wall ──
    g[0][37] = 'L'
    g[0][38] = 'L'

    # ── Pillars (symmetric on both sides) ──
    pillar_rows = [1, 7, 10, 13, 16, 19, 22]
    for y in pillar_rows:
        g[y][4] = 'P'
        g[y][35] = 'P'

    # ── Wall torches (between pillars) ──
    torch_rows = [2, 8, 11, 14, 17, 20]
    for y in torch_rows:
        g[y][1] = 'X'
        g[y][W - 2] = 'X'

    # ── Trophies near throne ──
    g[6][3]  = 'Y'
    g[6][36] = 'Y'
    g[2][3]  = 'Y'
    g[2][36] = 'Y'

    # ── Pokeball displays ──
    g[1][8]  = 'O'
    g[1][31] = 'O'

    # ── Arena entrance (left side, rows 12-13, cols 1-2) ──
    g[12][1] = 'A'
    g[12][2] = 'A'
    g[13][1] = 'A'
    g[13][2] = 'A'

    # ── Shop entrance (right side, rows 12-13, cols 37-38) ──
    g[12][W - 3] = 'S'
    g[12][W - 2] = 'S'
    g[13][W - 3] = 'S'
    g[13][W - 2] = 'S'

    # ── Bookshelves (lower area) ──
    for dy in [19, 20]:
        g[dy][3]  = 'B'
        g[dy][5]  = 'B'
        g[dy][34] = 'B'
        g[dy][36] = 'B'

    # ── Tables near arena/shop ──
    g[10][3]  = 'U'
    g[10][36] = 'U'

    # ── Statues flanking entrance from inside ──
    g[22][15] = 'M'
    g[22][24] = 'M'

    # ── Sign posts near doors ──
    g[11][3]  = 'N'    # near arena
    g[11][36] = 'N'    # near shop

    # ── Outdoor area (rows 24-29) ──
    for y in range(24, H):
        for x in range(W):
            g[y][x] = 'g'

    # Road / path (cols 14-25)
    for y in range(25, H):
        for x in range(14, 26):
            g[y][x] = 'r'

    # Entrance transition (row 24)
    for x in range(17, 23):
        g[24][x] = 'r'

    # Flowers
    flower_spots = [(5, 25), (6, 26), (33, 25), (34, 26),
                    (8, 28), (9, 28), (30, 28), (31, 28),
                    (3, 27), (36, 27)]
    for fx, fy in flower_spots:
        if 0 <= fx < W and 0 <= fy < H:
            g[fy][fx] = 'f'

    # Water features (small decorative pools outside)
    for wx in [3, 4, 35, 36]:
        for wy in [25, 26]:
            if g[wy][wx] == 'g':
                g[wy][wx] = '~'

    # Convert to strings
    tile_data = [''.join(row) for row in g]

    # ── NPCs ──
    npcs = []
    if league_members:
        npc_positions = [
            (8,  8,  'right'),   # left upper hall
            (31, 8,  'left'),    # right upper hall
            (8,  15, 'right'),   # left mid hall
            (31, 15, 'left'),    # right mid hall
            (8,  18, 'right'),   # left lower hall
            (31, 18, 'left'),    # right lower hall
        ]
        for i, (nx, ny, nd) in enumerate(npc_positions):
            if i < len(league_members) - 1:  # skip champion (last = player)
                member = league_members[i]
                npcs.append(NPC(
                    nx, ny, member.name, nd,
                    f"I am {member.display_name()}!\nI guard this League!",
                    member.name, 'league_member'
                ))

    # Guide NPC near entrance
    npcs.append(NPC(
        25, 21, "Guide", 'down',
        "Welcome, Champion!\n"
        "Use ARROW KEYS to move.\n"
        "Press SPACE to interact.\n"
        "Visit the ARENA to battle challengers\n"
        "or the SHOP to upgrade your team!",
        None, 'guide'
    ))

    return GameMap(tile_data, npcs, name="Champion's Hall")
